
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NotifType {
  ORDER_PLACED       // → sent to USER  when they place an order
  ORDER_CONFIRMED    // → sent to USER  when admin confirms
  ORDER_SHIPPED      // → sent to USER  when admin marks shipped
  ORDER_DELIVERED    // → sent to USER  when admin marks delivered
  ORDER_CANCELLED    // → sent to USER  when order is cancelled
  NEW_ORDER          // → sent to ADMIN when any user places an order
  LOW_STOCK          // → sent to ADMIN when variant stock drops below 5
}

// ─── User & Auth ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  password     String?  // nullable → future OAuth support (Google, GitHub)
  role         Role     @default(USER)
  isBanned     Boolean  @default(false)
  isSuperAdmin Boolean  @default(false) // only super-admin can promote others to ADMIN
  isVerified   Boolean  @default(false)
  verificationToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
resetToken   String?
resetTokenExpiry DateTime?
  // relations
  addresses     Address[]
  cartItems     CartItem[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]

  @@index([email])   // fast login lookup
  @@index([role])    // fast admin user list query
}

// Saved delivery addresses (reusable across orders)
model Address {
  id        String  @id @default(cuid())
  label     String  @default("Home")  // "Home", "Office", "Other"
  fullName  String
  phone     String
  line1     String
  line2     String? // apartment, floor, landmark
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders Order[] // orders placed using this address

  @@index([userId])
}

// ─── Catalog

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique // URL-safe: "mechanical-keyboards", "desk-mats"

  products Product[]
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  brand       String?
  slug        String  @unique // SEO URL: "keychron-k2-pro", "grovemade-desk-mat"
  isActive    Boolean @default(true) // false = hidden from store, NOT deleted

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  variants ProductVariant[]
  images   ProductImage[]
  reviews  Review[]

  @@index([categoryId])
  @@index([isActive])
  @@index([slug])
}

// Each sellable option of a product (e.g. "Red Switch / 65%", "Black / XL")
model ProductVariant {
  id    String @id @default(cuid())
  name  String // e.g. "Space Grey / Blue Switch"
  sku   String @unique
  price Int    // stored in PAISE — ₹1,299 = 129900
  stock Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([stock])  // fast low-stock query: WHERE stock < 5
}

// Multiple images per product
model ProductImage {
  id        String  @id @default(cuid())
  url       String
  altText   String? // accessibility + SEO
  isPrimary Boolean @default(false) // shown on product card
  sortOrder Int     @default(0)     // gallery order

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Product reviews (one per user per product)
model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1–5  (enforce in application layer: z.number().min(1).max(5))
  comment   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // one review per product per user — DB-level enforcement
  @@index([productId])
}

// ─── Cart ─────────────────────────────────────────────────────

model CartItem {
  id       String   @id @default(cuid())
  quantity Int      @default(1) // always >= 1, always <= variant.stock
  addedAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId]) // no duplicate rows — increment qty instead of inserting
  @@index([userId])
}

// ─── Orders ───────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  totalAmount Int         // stored in PAISE, sum of all OrderItems

  // Customer snapshot — denormalized so order stays correct even if user edits profile
  customerName  String
  customerEmail String

  adminNote String? // internal note visible only to admin, never to customer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Address snapshot via relation — address is locked at order time
  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  items         OrderItem[]
  notifications Notification[]

  @@index([userId])
  @@index([status])
  @@index([createdAt]) // fast date-range queries for admin dashboard
  @@index([customerEmail]) // fast search by email
}

// Each line item inside an order — fully snapshotted at checkout time
model OrderItem {
  id       String @id @default(cuid())
  quantity Int

  // SNAPSHOTS — never change even if product is edited or deleted later
  productName  String // e.g. "Keychron K2 Pro"
  variantName  String // e.g. "Space Grey / Red Switch"
  priceAtOrder Int    // price in PAISE at the moment of purchase

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  // NOTE: no onDelete Cascade here — we want to KEEP order history
  // even if the variant is later deleted from the catalog

  @@index([orderId])
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  type      NotifType
  title     String    // short: "Order confirmed"
  message   String    // full: "Your order #abc123 has been confirmed and is being prepared."
  link      String?   // deep link: "/orders/clx123" or "/admin/orders/clx123"
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  // nullable userId → future support for broadcast/system notifications
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // optional orderId → link notification to a specific order for quick navigation
  orderId String?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, isRead]) // THE most important index — powers the bell unread count
  @@index([userId, createdAt]) // fast notification inbox sorted by date
}
